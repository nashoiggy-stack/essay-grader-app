# Copy to .env.local and fill in real values. .env.local is gitignored.

# ── Supabase ─────────────────────────────────────────────────────────────
# New API key system (publishable + secret). Replaces the legacy
# anon JWT and service_role JWT. Issue from Supabase dashboard →
# Settings → API keys.

# Browser-safe URL + publishable key (RLS-gated, fine to inline in client
# bundles). NEXT_PUBLIC_ prefix tells Next.js to inline at build time.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only secret key (bypasses RLS — never expose to client). Used by
# /api/strategy/share/* through src/lib/supabase-admin.ts.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: LLM-driven free-text interest mapping on /colleges ────────
# Set to "true" to enable the /api/interest-map debounced fetcher that
# expands the user's free-text interest into related majors + keywords.
NEXT_PUBLIC_LLM_INTEREST_MAP=false
